        f_cell(t3, 3, 25, f_num(neg_mean_high20 * 100.0, "#.2") + "%", bg_a, text.align_right, size.tiny)

        f_cell(t3, 0, 27, "TRANSITION", bg_head, text.align_left, size.tiny)
        f_cell(t3, 1, 27, "HIGH->HIGH " + f_num(pHH, "#.1") + "%", f_pct_bg(pHH), text.align_right, size.tiny)
        f_cell(t3, 2, 27, "MID->MID " + f_num(pMM, "#.1") + "%", f_pct_bg(pMM), text.align_right, size.tiny)
        f_cell(t3, 3, 27, "LOW->LOW " + f_num(pLL, "#.1") + "%", f_pct_bg(pLL), text.align_right, size.tiny)

        f_cell(t3, 0, 28, "DECISION", bg_a, text.align_left, size.tiny)
        f_cell(t3, 1, 28, decision_bias, f_decision_bg(decision_bias), text.align_right, size.tiny)
        f_cell(t3, 2, 28, "Conf " + f_num(pred_conf, "#.0"), bg_a, text.align_right, size.tiny)
        f_cell(t3, 3, 28, pred_ready ? "PRED READY" : "PRED WAIT", pred_ready ? color.new(color.lime, 80) : color.new(color.orange, 70), text.align_right, size.tiny)

        note1 = "STRICT: percentiles; inference uses AR-AdjN; partial corr controls avg(IB,PR)."
        note2 = "PREDICTIVE: regime-conditional realized 5D/20D outcomes; statistical overlay, not causal model."
        f_cell(t3, 0, 29, note1, bg_title, text.align_left, size.small)
        f_cell(t3, 1, 29, "", bg_title, text.align_left, size.small)
        f_cell(t3, 2, 29, "", bg_title, text.align_left, size.small)
        f_cell(t3, 3, 29, "", bg_title, text.align_left, size.small)

        f_cell(t3, 0, 30, note2, bg_title, text.align_left, size.small)
        f_cell(t3, 1, 30, "", bg_title, text.align_left, size.small)
        f_cell(t3, 2, 30, "", bg_title, text.align_left, size.small)
        f_cell(t3, 3, 30, "", bg_title, text.align_left, size.small)
    else
        if not na(t3)
            table.delete(t3)
            t3 := na
