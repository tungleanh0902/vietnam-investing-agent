//@version=5
indicator("VN YieldCurveLab v1.8.1 — Academic Defaults + Predictive Overlay (STRICT, CLEAN)",
     shorttitle="VN YieldCurveLab 1.8.1",
     overlay=false,
     max_labels_count=500,
     max_lines_count=500,
     max_bars_back=5000,
     precision=4)

//======================================================
// 0) INPUT (ONLY PANEL)
//======================================================
panel_view = input.int(1, "Panel (1=Shape, 2=Grid, 3=Research+Predictive)", minval=1, maxval=3)
show_p1 = panel_view == 1
show_p2 = panel_view == 2
show_p3 = panel_view == 3

//======================================================
// 1) ACADEMIC DEFAULTS (STRICT, HARD-CODED)
//======================================================
string TF_DATA = "D"

// Windows
int LEN_STATS    = 252
int LEN_RESEARCH = 252
int LEN_HALF     = 126
int LEN_STAB     = 60

// Robustness
float CLIP_Z      = 2.5
float RET_CLIP_SD = 3.0

// Research gates
float MIN_EFF_RATIO = 0.80
float COV_MED       = 0.85
float COV_HIGH      = 0.95

// BestLag discipline
int   LAG1 = 1
int   LAG2 = 5
int   LAG3 = 20
float R_ACCEPT   = 0.20
float MARGIN_MIN = 0.05
float T_CRIT     = 2.4
float R_HALF_MIN = 0.15

// Stress percentile thresholds
float STRESS_LOW_PCTL  = 20.0
float STRESS_HIGH_PCTL = 80.0

// Predictive overlay
int   H5  = 5
int   H20 = 20
float HIT_ACCEPT     = 55.0
float PERSIST_ACCEPT = 55.0
float PRED_MIN_RATIO = 0.10

// Symbols
string SYM_1Y  = "TVC:VN01Y"
string SYM_2Y  = "TVC:VN02Y"
string SYM_3Y  = "TVC:VN03Y"
string SYM_5Y  = "TVC:VN05Y"
string SYM_7Y  = "TVC:VN07Y"
string SYM_10Y = "TVC:VN10Y"
string SYM_IB  = "VNINBR"
string SYM_PR  = "VNINTR"
string SYM_VNX = "HOSE:VNINDEX"

//======================================================
// 2) HELPERS
//======================================================
f_robust_z(src, length, clip) =>
    m  = ta.sma(src, length)
    sd = ta.stdev(src, length)
    up = m + clip * sd
    dn = m - clip * sd
    clipped = math.max(dn, math.min(up, src))
    cm  = ta.sma(clipped, length)
    csd = ta.stdev(clipped, length)
    csd > 0 ? (src - cm) / csd : 0.0

f_num(v, fmt) =>
    string s = "NA"
    if not na(v)
        s := str.tostring(v, fmt)
    s

f_count(cond, length) =>
    float v  = cond ? 1.0 : 0.0
    float cs = ta.cum(v)
    cs - nz(cs[length])

f_sum(x, length) =>
    float cs = ta.cum(x)
    cs - nz(cs[length])

f_t_from_df(r, df) =>
    float t = na
    if not na(r) and not na(df) and df > 0 and math.abs(r) < 1
        t := r * math.sqrt(df / (1 - r * r))
    t

f_partial_corr(r_xy, r_xz, r_yz) =>
    float out = na
    if not na(r_xy) and not na(r_xz) and not na(r_yz)
        float den = math.sqrt((1 - r_xz * r_xz) * (1 - r_yz * r_yz))
        out := den > 0 ? (r_xy - r_xz * r_yz) / den : na
    out

f_bg_tag(tag) =>
    color out = color.new(color.gray, 85)
    if tag == "HIGH" or tag == "RICH" or tag == "YC4" or tag == "INVERTED" or tag == "STRESS HIGH" or tag == "LOWQ" or tag == "DATAQ LOW" or tag == "DEFENSIVE"
        out := color.new(color.red, 12)
    else if tag == "LOW" or tag == "CHEAP" or tag == "YC1" or tag == "STRESS LOW" or tag == "HIGHQ" or tag == "DATAQ HIGH" or tag == "RISK-ON"
        out := color.new(color.lime, 14)
    else
        out := color.new(color.orange, 16)
    out

f_corrBg(float r) =>
    color bg = color.new(color.black, 80)
    if not na(r)
        float a = math.abs(r)
        int tr =
             a >= 0.50 ? 10 :
             a >= 0.35 ? 25 :
             a >= 0.20 ? 45 :
             a >= 0.10 ? 65 : 80
        color base = r >= 0 ? color.lime : color.red
        bg := color.new(base, tr)
    bg

f_pct_bg(v) =>
    color bg = color.new(color.black, 80)
    if not na(v)
        bg := v >= 60 ? color.new(color.red, 10) : v <= 40 ? color.new(color.lime, 15) : color.new(color.orange, 20)
    bg

f_decision_bg(tag) =>
    color out = color.new(color.orange, 18)
    if tag == "DEFENSIVE"
        out := color.new(color.red, 10)
    else if tag == "RISK-ON"
        out := color.new(color.lime, 12)
    else
        out := color.new(color.orange, 16)
    out

//======================================================
// 3) DATA
//======================================================
y1_raw  = request.security(SYM_1Y,  TF_DATA, close, barmerge.gaps_on,  barmerge.lookahead_off)
y2_raw  = request.security(SYM_2Y,  TF_DATA, close, barmerge.gaps_on,  barmerge.lookahead_off)
y3_raw  = request.security(SYM_3Y,  TF_DATA, close, barmerge.gaps_on,  barmerge.lookahead_off)
y5_raw  = request.security(SYM_5Y,  TF_DATA, close, barmerge.gaps_on,  barmerge.lookahead_off)
y7_raw  = request.security(SYM_7Y,  TF_DATA, close, barmerge.gaps_on,  barmerge.lookahead_off)
y10_raw = request.security(SYM_10Y, TF_DATA, close, barmerge.gaps_on,  barmerge.lookahead_off)
ib_raw  = request.security(SYM_IB,  TF_DATA, close, barmerge.gaps_on,  barmerge.lookahead_off)
pr_raw  = request.security(SYM_PR,  TF_DATA, close, barmerge.gaps_on,  barmerge.lookahead_off)

vnx = request.security(SYM_VNX, TF_DATA, close, barmerge.gaps_off, barmerge.lookahead_off)

var float y1  = na
var float y2  = na
var float y3  = na
var float y5  = na
var float y7  = na
var float y10 = na
var float ib  = na
var float pr  = na

y1  := na(y1_raw)  ? nz(y1[1])  : y1_raw
y2  := na(y2_raw)  ? nz(y2[1])  : y2_raw
y3  := na(y3_raw)  ? nz(y3[1])  : y3_raw
y5  := na(y5_raw)  ? nz(y5[1])  : y5_raw
y7  := na(y7_raw)  ? nz(y7[1])  : y7_raw
y10 := na(y10_raw) ? nz(y10[1]) : y10_raw
ib  := na(ib_raw)  ? nz(ib[1])  : ib_raw
pr  := na(pr_raw)  ? nz(pr[1])  : pr_raw

vnx_ret = (not na(vnx) and not na(vnx[1]) and vnx[1] > 0) ? math.log(vnx / vnx[1]) : na

ret_mean = ta.sma(vnx_ret, LEN_RESEARCH)
ret_sd   = ta.stdev(vnx_ret, LEN_RESEARCH)
ret_up   = ret_mean + RET_CLIP_SD * ret_sd
ret_dn   = ret_mean - RET_CLIP_SD * ret_sd
vnx_ret_clip = (not na(vnx_ret) and not na(ret_sd) and ret_sd > 0) ? math.max(ret_dn, math.min(ret_up, vnx_ret)) : vnx_ret

//======================================================
// 4) FACTORS
//======================================================
level = (y2 + y5 + y10) / 3.0
slope = y10 - y2
curve = 2.0 * y5 - y2 - y10

level_pct = ta.percentrank(level, LEN_STATS)
slope_pct = ta.percentrank(slope, LEN_STATS)
curve_pct = ta.percentrank(curve, LEN_STATS)

level_comp = level_pct
slope_risk = slope <= 0 ? 100.0 : (100.0 - slope_pct)
curve_risk = not na(curve_pct) ? (math.abs(curve_pct - 50.0) / 50.0) * 100.0 : na

macro_stress = (0.45 * level_comp) + (0.45 * slope_risk) + (0.10 * curve_risk)

//======================================================
// 5) QUALITY
//======================================================
y1_z  = f_robust_z(y1,  LEN_STATS, CLIP_Z)
y2_z  = f_robust_z(y2,  LEN_STATS, CLIP_Z)
y3_z  = f_robust_z(y3,  LEN_STATS, CLIP_Z)
y5_z  = f_robust_z(y5,  LEN_STATS, CLIP_Z)
y7_z  = f_robust_z(y7,  LEN_STATS, CLIP_Z)
y10_z = f_robust_z(y10, LEN_STATS, CLIP_Z)

mean_z = (y1_z + y2_z + y3_z + y5_z + y7_z + y10_z) / 6.0
dz1  = y1_z  - mean_z
dz2  = y2_z  - mean_z
dz3  = y3_z  - mean_z
dz5  = y5_z  - mean_z
dz7  = y7_z  - mean_z
dz10 = y10_z - mean_z

var_z = (dz1 * dz1 + dz2 * dz2 + dz3 * dz3 + dz5 * dz5 + dz7 * dz7 + dz10 * dz10) / 6.0
dist  = math.sqrt(var_z)

dist_label = dist < 0.30 ? "PURE" : dist > 0.70 ? "DISTORTED" : "MIXED"

dist_clamp  = math.min(1.2, math.max(0.0, dist))
qual_struct = 100.0 - (dist_clamp / 1.2) * 100.0

core_raw_ok = (not na(y2_raw)) and (not na(y5_raw)) and (not na(y10_raw))
cov_core = f_count(core_raw_ok, LEN_RESEARCH) / LEN_RESEARCH
qual_data = cov_core * 100.0

qual_total = math.min(qual_struct, qual_data)
quality_label =
     qual_total >= 75 ? "HIGHQ" :
     qual_total >= 50 ? "MEDQ"  : "LOWQ"

dataq_label =
     cov_core >= COV_HIGH ? "DATAQ HIGH" :
     cov_core >= COV_MED  ? "DATAQ MED"  : "DATAQ LOW"

stress_adj = macro_stress * (qual_total / 100.0)

stress_pct  = ta.percentrank(macro_stress, LEN_STATS)
stressA_pct = ta.percentrank(stress_adj,   LEN_STATS)

stress_reg =
     stressA_pct >= STRESS_HIGH_PCTL ? "STRESS HIGH" :
     stressA_pct <= STRESS_LOW_PCTL  ? "STRESS LOW"  : "MID"

//======================================================
// 6) YC REGIME
//======================================================
level_reg = level_pct >= 80 ? "HIGH" : level_pct <= 20 ? "LOW" : "MID"
slope_reg =
     slope <= 0 ? "INVERTED" :
     slope_pct >= 80 ? "STEEP_HIGH" :
     slope_pct <= 20 ? "STEEP_LOW"  : "FLAT"

string yc_code  = "YC0"
string yc_label = "Neutral/Mixed."
if level_reg == "HIGH" and (slope_reg == "FLAT" or slope_reg == "INVERTED")
    yc_code  := "YC4"
    yc_label := "Tight: high level + flat/inverted."
else if level_reg == "HIGH" and slope_reg == "STEEP_HIGH"
    yc_code  := "YC3"
    yc_label := "Late tightening: high level + steep."
else if level_reg == "LOW" and slope_reg == "STEEP_HIGH"
    yc_code  := "YC2"
    yc_label := "Early easing: low level + steep."
else if level_reg == "LOW"
    yc_code  := "YC1"
    yc_label := "Easing mature: low level."

//======================================================
// 7) PLOTS
//======================================================
plot(y2,  "VN02Y",  color.new(color.blue, 0),   2)
plot(y5,  "VN05Y",  color.new(color.green, 0),  2)
plot(y10, "VN10Y",  color.new(color.red, 0),    2)
plot(y1,  "VN01Y",  color.new(color.gray, 60),  1)
plot(y3,  "VN03Y",  color.new(color.orange,60), 1)
plot(y7,  "VN07Y",  color.new(color.purple,60), 1)
plot(ib,  "VNINBR", color.new(color.yellow,0),  1)
plot(pr,  "VNINTR", color.new(color.teal, 0),   1)

min12   = math.min(y1, y2)
min35   = math.min(y3, y5)
min710  = math.min(y7, y10)
yc_min6 = math.min(math.min(min12, min35), min710)

max12   = math.max(y1, y2)
max35   = math.max(y3, y5)
max710  = math.max(y7, y10)
yc_max6 = math.max(math.max(max12, max35), max710)

y_min = ta.lowest(yc_min6, LEN_STATS)
y_max = ta.highest(yc_max6, LEN_STATS)
y_rng = y_max - y_min

stress_map = y_min + (stressA_pct / 100.0) * (y_rng > 0 ? y_rng : 1.0)
plot(stress_map, "StressPCTL(mapped)", color.new(color.white, 35), 2)

//======================================================
// 8) RESEARCH CORE (STRICT)
//======================================================
bool tf_ok = timeframe.isdaily
int  needBars = LEN_STATS + LEN_RESEARCH + LAG3 + H20 + 30
bool enoughBars = bar_index >= needBars

bool valid_all = tf_ok and enoughBars and core_raw_ok and (not na(stressA_pct)) and (not na(vnx_ret_clip))

float n_eff = f_count(valid_all, LEN_RESEARCH)
float ratio = n_eff / LEN_RESEARCH
bool  ready = (ratio >= MIN_EFF_RATIO) and (cov_core >= COV_MED) and tf_ok and enoughBars

float rhoS = ta.correlation(stressA_pct, stressA_pct[1], LEN_RESEARCH)
float rhoR = ta.correlation(vnx_ret_clip, vnx_ret_clip[1], LEN_RESEARCH)
float cdi  = rhoS * rhoR

float n_eff_ar = na
bool  persist_on = false
if ready and not na(cdi) and math.abs(cdi) < 0.98 and (1 + cdi) != 0
    n_eff_ar := n_eff * (1 - cdi) / (1 + cdi)
    n_eff_ar := math.max(5.0, math.min(n_eff, n_eff_ar))
    persist_on := true

float df_corr  = (persist_on and not na(n_eff_ar)) ? (n_eff_ar - 2.0) : na
float df_pcorr = (persist_on and not na(n_eff_ar)) ? (n_eff_ar - 3.0) : na

float corr_raw = ta.correlation(stress_pct,  vnx_ret_clip, LEN_RESEARCH)
float corr_adj = ta.correlation(stressA_pct, vnx_ret_clip, LEN_RESEARCH)
float r2_adj   = not na(corr_adj) ? corr_adj * corr_adj : na
float t_adj_ar = f_t_from_df(corr_adj, df_corr)

float ctrl = (ib + pr) / 2.0
float ctrl_pct = ta.percentrank(ctrl, LEN_STATS)
float r_xz = ta.correlation(stressA_pct,  ctrl_pct, LEN_RESEARCH)
float r_yz = ta.correlation(vnx_ret_clip, ctrl_pct, LEN_RESEARCH)
float pcorr = f_partial_corr(corr_adj, r_xz, r_yz)
float t_pcorr_ar = f_t_from_df(pcorr, df_pcorr)

float rL1  = ta.correlation(stressA_pct[LAG1], vnx_ret_clip, LEN_RESEARCH)
float rL5  = ta.correlation(stressA_pct[LAG2], vnx_ret_clip, LEN_RESEARCH)
float rL20 = ta.correlation(stressA_pct[LAG3], vnx_ret_clip, LEN_RESEARCH)

// Precompute half-window lag correlations on every bar
float rL1_half  = ta.correlation(stressA_pct[LAG1], vnx_ret_clip, LEN_HALF)
float rL5_half  = ta.correlation(stressA_pct[LAG2], vnx_ret_clip, LEN_HALF)
float rL20_half = ta.correlation(stressA_pct[LAG3], vnx_ret_clip, LEN_HALF)

int   bestLag = na
float bestCorr = na
float secondAbs = na
float margin = na
float bestCorr_half = na
bool  half_ok = false

if ready
    float a1 = math.abs(rL1)
    float a2 = math.abs(rL5)
    float a3 = math.abs(rL20)

    bestLag  := a1 >= a2 and a1 >= a3 ? LAG1 : (a2 >= a3 ? LAG2 : LAG3)
    bestCorr := a1 >= a2 and a1 >= a3 ? rL1  : (a2 >= a3 ? rL5  : rL20)

    secondAbs := bestLag == LAG1 ? math.max(a2, a3) : bestLag == LAG2 ? math.max(a1, a3) : math.max(a1, a2)
    margin := (not na(bestCorr) and not na(secondAbs)) ? (math.abs(bestCorr) - secondAbs) : na

    bestCorr_half := bestLag == LAG1 ? rL1_half : bestLag == LAG2 ? rL5_half : rL20_half

    half_ok := not na(bestCorr) and not na(bestCorr_half) and (math.sign(bestCorr) == math.sign(bestCorr_half)) and (math.abs(bestCorr_half) >= R_HALF_MIN)
else
    half_ok := false

float t_best = f_t_from_df(bestCorr, df_corr)

bool best_accept = ready and persist_on and half_ok and
     (not na(margin) and margin >= MARGIN_MIN) and
     (not na(bestCorr) and math.abs(bestCorr) >= R_ACCEPT) and
     (not na(t_best) and math.abs(t_best) >= T_CRIT)

float eff_stab = f_count(not na(bestLag), LEN_STAB)
float chg_stab = f_count(not na(bestLag) and (bestLag != bestLag[1]), LEN_STAB)
float stab_pct = eff_stab > 0 ? 100.0 * (1.0 - chg_stab / eff_stab) : na

//======================================================
// 9) PREDICTIVE OVERLAY (LIGHTWEIGHT, CLEAN)
//======================================================
ret5_now  = (not na(vnx) and not na(vnx[H5])  and vnx[H5]  > 0) ? math.log(vnx / vnx[H5])  : na
ret20_now = (not na(vnx) and not na(vnx[H20]) and vnx[H20] > 0) ? math.log(vnx / vnx[H20]) : na

bool valid_pred5  = tf_ok and enoughBars and core_raw_ok[H5]  and (not na(stressA_pct[H5]))  and (not na(ret5_now))
bool valid_pred20 = tf_ok and enoughBars and core_raw_ok[H20] and (not na(stressA_pct[H20])) and (not na(ret20_now))

bool low5  = valid_pred5  and stressA_pct[H5]  <= STRESS_LOW_PCTL
bool mid5  = valid_pred5  and stressA_pct[H5]  > STRESS_LOW_PCTL and stressA_pct[H5]  < STRESS_HIGH_PCTL
bool high5 = valid_pred5  and stressA_pct[H5]  >= STRESS_HIGH_PCTL

bool low20  = valid_pred20 and stressA_pct[H20] <= STRESS_LOW_PCTL
bool mid20  = valid_pred20 and stressA_pct[H20] > STRESS_LOW_PCTL and stressA_pct[H20] < STRESS_HIGH_PCTL
bool high20 = valid_pred20 and stressA_pct[H20] >= STRESS_HIGH_PCTL

float n_low5  = f_count(low5,  LEN_RESEARCH)
float n_mid5  = f_count(mid5,  LEN_RESEARCH)
float n_high5 = f_count(high5, LEN_RESEARCH)

float n_low20  = f_count(low20,  LEN_RESEARCH)
float n_mid20  = f_count(mid20,  LEN_RESEARCH)
float n_high20 = f_count(high20, LEN_RESEARCH)

// Precompute all sums / counts every bar
float sum_low5  = f_sum(low5  ? ret5_now  : 0.0, LEN_RESEARCH)
float sum_mid5  = f_sum(mid5  ? ret5_now  : 0.0, LEN_RESEARCH)
float sum_high5 = f_sum(high5 ? ret5_now  : 0.0, LEN_RESEARCH)

float sum_low20  = f_sum(low20  ? ret20_now : 0.0, LEN_RESEARCH)
float sum_mid20  = f_sum(mid20  ? ret20_now : 0.0, LEN_RESEARCH)
float sum_high20 = f_sum(high20 ? ret20_now : 0.0, LEN_RESEARCH)

float cnt_dn_low5  = f_count(low5  and ret5_now  < 0, LEN_RESEARCH)
float cnt_dn_mid5  = f_count(mid5  and ret5_now  < 0, LEN_RESEARCH)
float cnt_dn_high5 = f_count(high5 and ret5_now  < 0, LEN_RESEARCH)

float cnt_dn_low20  = f_count(low20  and ret20_now < 0, LEN_RESEARCH)
float cnt_dn_mid20  = f_count(mid20  and ret20_now < 0, LEN_RESEARCH)
float cnt_dn_high20 = f_count(high20 and ret20_now < 0, LEN_RESEARCH)

float sum_dn_low5  = f_sum((low5  and ret5_now  < 0) ? ret5_now  : 0.0, LEN_RESEARCH)
float sum_dn_mid5  = f_sum((mid5  and ret5_now  < 0) ? ret5_now  : 0.0, LEN_RESEARCH)
float sum_dn_high5 = f_sum((high5 and ret5_now  < 0) ? ret5_now  : 0.0, LEN_RESEARCH)

float sum_dn_low20  = f_sum((low20  and ret20_now < 0) ? ret20_now : 0.0, LEN_RESEARCH)
float sum_dn_mid20  = f_sum((mid20  and ret20_now < 0) ? ret20_now : 0.0, LEN_RESEARCH)
float sum_dn_high20 = f_sum((high20 and ret20_now < 0) ? ret20_now : 0.0, LEN_RESEARCH)

float mean_low5  = n_low5  > 0 ? sum_low5  / n_low5  : na
float mean_mid5  = n_mid5  > 0 ? sum_mid5  / n_mid5  : na
float mean_high5 = n_high5 > 0 ? sum_high5 / n_high5 : na

float mean_low20  = n_low20  > 0 ? sum_low20  / n_low20  : na
float mean_mid20  = n_mid20  > 0 ? sum_mid20  / n_mid20  : na
float mean_high20 = n_high20 > 0 ? sum_high20 / n_high20 : na

float hitDn_low5  = n_low5  > 0 ? 100.0 * cnt_dn_low5  / n_low5  : na
float hitDn_mid5  = n_mid5  > 0 ? 100.0 * cnt_dn_mid5  / n_mid5  : na
float hitDn_high5 = n_high5 > 0 ? 100.0 * cnt_dn_high5 / n_high5 : na

float hitDn_low20  = n_low20  > 0 ? 100.0 * cnt_dn_low20  / n_low20  : na
float hitDn_mid20  = n_mid20  > 0 ? 100.0 * cnt_dn_mid20  / n_mid20  : na
float hitDn_high20 = n_high20 > 0 ? 100.0 * cnt_dn_high20 / n_high20 : na

float neg_mean_low5  = cnt_dn_low5  > 0 ? sum_dn_low5  / cnt_dn_low5  : na
float neg_mean_mid5  = cnt_dn_mid5  > 0 ? sum_dn_mid5  / cnt_dn_mid5  : na
float neg_mean_high5 = cnt_dn_high5 > 0 ? sum_dn_high5 / cnt_dn_high5 : na

float neg_mean_low20  = cnt_dn_low20  > 0 ? sum_dn_low20  / cnt_dn_low20  : na
float neg_mean_mid20  = cnt_dn_mid20  > 0 ? sum_dn_mid20  / cnt_dn_mid20  : na
float neg_mean_high20 = cnt_dn_high20 > 0 ? sum_dn_high20 / cnt_dn_high20 : na

float min_bucket = LEN_RESEARCH * PRED_MIN_RATIO
bool pred5_enough  = (n_low5 >= min_bucket) and (n_mid5 >= min_bucket) and (n_high5 >= min_bucket)
bool pred20_enough = (n_low20 >= min_bucket) and (n_mid20 >= min_bucket) and (n_high20 >= min_bucket)
bool pred_ready = ready and pred5_enough and pred20_enough

float exp5 = stress_reg == "STRESS HIGH" ? mean_high5 : stress_reg == "STRESS LOW" ? mean_low5 : mean_mid5
float exp20 = stress_reg == "STRESS HIGH" ? mean_high20 : stress_reg == "STRESS LOW" ? mean_low20 : mean_mid20

float hit5 = stress_reg == "STRESS HIGH" ? hitDn_high5 : stress_reg == "STRESS LOW" ? hitDn_low5 : hitDn_mid5
float hit20 = stress_reg == "STRESS HIGH" ? hitDn_high20 : stress_reg == "STRESS LOW" ? hitDn_low20 : hitDn_mid20

float neg5 = stress_reg == "STRESS HIGH" ? neg_mean_high5 : stress_reg == "STRESS LOW" ? neg_mean_low5 : neg_mean_mid5
float neg20 = stress_reg == "STRESS HIGH" ? neg_mean_high20 : stress_reg == "STRESS LOW" ? neg_mean_low20 : neg_mean_mid20

// Transition persistence
int stress_state = stressA_pct >= STRESS_HIGH_PCTL ? 3 : stressA_pct <= STRESS_LOW_PCTL ? 1 : 2

bool trans_valid = tf_ok and enoughBars and (not na(stress_state)) and (not na(stress_state[1]))
bool from_high = trans_valid and stress_state[1] == 3
bool from_mid  = trans_valid and stress_state[1] == 2
bool from_low  = trans_valid and stress_state[1] == 1

float n_from_high = f_count(from_high, LEN_RESEARCH)
float n_from_mid  = f_count(from_mid,  LEN_RESEARCH)
float n_from_low  = f_count(from_low,  LEN_RESEARCH)

float cnt_HH = f_count(from_high and stress_state == 3, LEN_RESEARCH)
float cnt_HM = f_count(from_high and stress_state == 2, LEN_RESEARCH)
float cnt_HL = f_count(from_high and stress_state == 1, LEN_RESEARCH)

float cnt_LL = f_count(from_low and stress_state == 1, LEN_RESEARCH)
float cnt_LM = f_count(from_low and stress_state == 2, LEN_RESEARCH)
float cnt_LH = f_count(from_low and stress_state == 3, LEN_RESEARCH)

float cnt_MM = f_count(from_mid and stress_state == 2, LEN_RESEARCH)

float pHH = n_from_high > 0 ? 100.0 * cnt_HH / n_from_high : na
float pHM = n_from_high > 0 ? 100.0 * cnt_HM / n_from_high : na
float pHL = n_from_high > 0 ? 100.0 * cnt_HL / n_from_high : na

float pLL = n_from_low > 0 ? 100.0 * cnt_LL / n_from_low : na
float pLM = n_from_low > 0 ? 100.0 * cnt_LM / n_from_low : na
float pLH = n_from_low > 0 ? 100.0 * cnt_LH / n_from_low : na

float pMM = n_from_mid > 0 ? 100.0 * cnt_MM / n_from_mid : na

float regime_persist =
     stress_reg == "STRESS HIGH" ? pHH :
     stress_reg == "STRESS LOW"  ? pLL : pMM

float pred_ratio_cur = stress_reg == "STRESS HIGH" ? (n_high5 / LEN_RESEARCH) : stress_reg == "STRESS LOW" ? (n_low5 / LEN_RESEARCH) : (n_mid5 / LEN_RESEARCH)
float conf_sample  = math.min(100.0, pred_ratio_cur * 300.0)
float conf_infer   = best_accept ? 100.0 : 60.0
float conf_persist = not na(regime_persist) ? regime_persist : 50.0
float pred_conf    = math.min(qual_total, math.min(conf_sample, math.min(conf_infer, conf_persist)))

string decision_bias = "NEUTRAL"
if pred_ready
    if stress_reg == "STRESS HIGH" and not na(exp5) and not na(hit5) and exp5 < 0 and hit5 >= HIT_ACCEPT and nz(regime_persist, 0) >= PERSIST_ACCEPT
        decision_bias := "DEFENSIVE"
    else if stress_reg == "STRESS LOW" and not na(exp5) and not na(hit5) and exp5 > 0 and hit5 <= (100.0 - HIT_ACCEPT) and nz(regime_persist, 0) >= PERSIST_ACCEPT
        decision_bias := "RISK-ON"
    else
        decision_bias := "NEUTRAL"

string pred_note =
     not pred_ready ? "PRED WAIT" :
     decision_bias == "DEFENSIVE" ? "Bias phong thu." :
     decision_bias == "RISK-ON" ? "Bias thuan rui ro." : "Bias trung tinh."

